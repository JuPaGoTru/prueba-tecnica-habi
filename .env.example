# Copy this file to .env and fill in your values
# cp .env.example .env

# Database
DATABASE_URL=postgresql+asyncpg://habi:habi@db:5432/habi_db

# JWT
SECRET_KEY=change-this-to-a-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Test database (used when running tests inside the container)
TEST_DATABASE_URL=postgresql+asyncpg://habi:habi@db:5432/habi_test
